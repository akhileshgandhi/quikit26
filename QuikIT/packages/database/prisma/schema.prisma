// ============================================================================
// APP MODULE FLAGS (FF-1) — per-tenant module gating
// ============================================================================
//
// Sparse storage: row exists iff a module is explicitly DISABLED for the
// given tenant × app. Absence of a row = module is enabled (the default).
//
// The canonical list of moduleKeys lives in packages/shared/lib/moduleRegistry.ts.
// Enforcement: sidebar filters by registry + disabled-set; layout.tsx gates
// redirect; API handlers return 404 when a disabled moduleKey is targeted.
// See docs/plans/FF-1-app-feature-flags.md for the full design.

model AppModuleFlag {
  id         String   @id @default(cuid())
  tenantId   String
  appId      String
  moduleKey  String   // e.g. "kpi", "kpi.teams", "opsp.review"
  enabled    Boolean  @default(false) // only stored when disabled; kept for future flexibility
  updatedBy  String?                   // super admin user id
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  app    App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([tenantId, appId, moduleKey])
  @@index([tenantId, appId])
}

// ============================================================================
// SUPER ADMIN — PHASE A INSTRUMENTATION
// Event capture layer that feeds analytics dashboards, health checks, alerts,
// session tracking, broadcasts, tenant-app gating, and plan/invoice data.
// See docs/plans/SA-A-instrumentation.md for the product plan.
// ============================================================================

/// Raw log of every API request across all apps. 30-day retention policy
/// (cleanup cron at /api/super/cron/cleanup-api-calls). Aggregated hourly
/// into ApiCallHourlyRollup for long-term trend analysis.
model ApiCall {
  id          String   @id @default(cuid())
  tenantId    String?  // null for pre-auth calls (login, OAuth flow)
  userId      String?
  appSlug     String   // "quikit" | "quikscale" | "admin"
  method      String   // GET | POST | PUT | PATCH | DELETE
  path        String   // full request path, no query string
  pathPattern String   // normalized: /api/kpi/[id] instead of /api/kpi/cl...
  statusCode  Int
  durationMs  Int
  ipAddress   String?
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([appSlug, createdAt])
  @@index([createdAt]) // retention cleanup
  @@index([userId, createdAt])
}

/// Hourly aggregation of ApiCall rows. Source of truth for all per-tenant
/// analytics older than a few hours. Populated by /api/super/cron/rollup-api-calls.
model ApiCallHourlyRollup {
  id              String   @id @default(cuid())
  tenantId        String?
  appSlug         String
  hourBucket      DateTime // truncated to the hour (UTC)
  method          String
  pathPattern     String
  statusClass     String   // "2xx" | "3xx" | "4xx" | "5xx"
  callCount       Int      @default(0)
  errorCount      Int      @default(0) // non-2xx
  totalDurationMs BigInt   @default(0) // sum, for avg calc
  maxDurationMs   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, appSlug, hourBucket, method, pathPattern, statusClass])
  @@index([tenantId, hourBucket])
  @@index([appSlug, hourBucket])
  @@index([hourBucket])
}

/// Uptime probe record. Written by /api/super/cron/health-check which pings
/// each registered app's /api/health endpoint every 5 minutes.
model AppHealthCheck {
  id         String   @id @default(cuid())
  appId      String
  status     String   // "up" | "down" | "degraded"
  statusCode Int?     // HTTP response code, null on network error
  durationMs Int?
  error      String?  @db.Text
  checkedAt  DateTime @default(now())

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId, checkedAt])
  @@index([checkedAt])
}

/// Auth lifecycle events — feeds DAU/MAU and "last login" on tenant health panel.
/// Appended to on login, logout, and (future) impersonation start/end.
model SessionEvent {
  id        String   @id @default(cuid())
  tenantId  String?  // null during pre-org-selection flow
  userId    String
  event     String   // "login" | "logout" | "impersonation_start" | "impersonation_end"
  appSlug   String?  // which app the user signed into (for cross-app DAU)
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([event, createdAt])
}

/// Platform-wide announcement banner shown to tenants. Managed via super admin
/// broadcast UI. Empty targetTenantIds = all tenants; empty targetAppSlugs = all apps.
model BroadcastAnnouncement {
  id              String    @id @default(cuid())
  title           String
  body            String    @db.Text
  severity        String    @default("info") // "info" | "warning" | "critical"
  targetTenantIds String[]
  targetAppSlugs  String[]
  startsAt        DateTime  @default(now())
  endsAt          DateTime?
  createdBy       String    // super admin user id
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  dismissals BroadcastDismissal[]

  @@index([startsAt])
  @@index([endsAt])
}

/// Per-user dismissal tracking — once dismissed, the banner doesn't resurface.
model BroadcastDismissal {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  dismissedAt    DateTime @default(now())

  announcement BroadcastAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
}

/// Hard gate: if enabled=false the tenant cannot access this app at all,
/// regardless of AppModuleFlag state. Evaluated first in the auth/route flow.
/// Sparse: row exists only when explicitly toggled off (default = enabled).
model TenantAppAccess {
  id        String   @id @default(cuid())
  tenantId  String
  appId     String
  enabled   Boolean  @default(true)
  reason    String?  // optional reason shown to tenant (e.g. "trial expired")
  updatedBy String?  // super admin user id
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  app    App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([tenantId, appId])
  @@index([tenantId])
  @@index([appId])
}

/// Plan definitions as data (replaces the current hardcoded "startup|growth|enterprise"
/// strings). Tenant.plan still stores the slug — no FK enforced yet so existing rows
/// don't break when a plan is deleted. Migration path: add FK after backfill.
model Plan {
  id           String   @id @default(cuid())
  slug         String   @unique // matches Tenant.plan
  name         String
  description  String?  @db.Text
  priceMonthly Int      @default(0) // cents, avoids Decimal precision issues
  priceYearly  Int      @default(0)
  currency     String   @default("USD")
  limits       Json?    // { "maxUsers": 10, "maxKPIs": 50, "maxApps": 3 }
  features     String[] // free-form feature tags
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
}

/// SA-D — Impersonation session record.
///
/// A super admin clicks "View as" on a tenant, which creates one of these
/// rows with a short-lived single-use token. The target app validates the
/// token, signs the super admin in AS the target user (with the
/// impersonation flag carried in the JWT), and deletes the token.
///
/// All actions during impersonation are tagged with impersonatingSuperAdminId
/// in the audit log so customer-support activity is distinguishable from
/// user activity.
model Impersonation {
  id                  String    @id @default(cuid())
  /// User who initiated the impersonation (a platform super admin).
  superAdminId        String
  /// The tenant whose app is being accessed.
  targetTenantId      String
  /// The user whose identity will be assumed (usually an org admin).
  targetUserId        String
  /// Which app to land in after token exchange ("quikscale" | "admin").
  targetAppSlug       String
  /// Opaque single-use token — 32-byte base64url. Consumed on accept.
  token               String    @unique
  /// Absolute expiry — rejected after this regardless of usage.
  expiresAt           DateTime
  /// Populated when the token is redeemed; null means still pending.
  acceptedAt          DateTime?
  /// Populated when the super admin explicitly exits the session.
  exitedAt            DateTime?
  /// Free-form reason captured at start time for audit.
  reason              String?
  ipAddress           String?
  createdAt           DateTime  @default(now())

  @@index([superAdminId, createdAt])
  @@index([targetTenantId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([expiresAt])
}

/// Platform alerts raised by the alerts engine cron. Super admins see these
/// as a dismissable list on the Analytics dashboard. Sparse — rows only
/// exist for currently-firing conditions. Resolved alerts are soft-deleted
/// by setting resolvedAt.
model PlatformAlert {
  id         String    @id @default(cuid())
  rule       String    // "app_down" | "api_error_spike" | "payment_failed" | "tenant_inactive"
  severity   String    @default("warning") // "info" | "warning" | "critical"
  title      String
  message    String    @db.Text
  /// Free-form identifier for the alert subject (appId, tenantId, etc) — used
  /// for dedupe so the same condition doesn't fire twice.
  subjectKey String
  /// Optional link for click-through ("/organizations/<tenantId>")
  link       String?
  data       Json?     // raw metrics that triggered the alert
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  resolvedAt  DateTime?
  acknowledgedAt DateTime?
  acknowledgedBy String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([resolvedAt])
  @@index([severity, lastSeenAt])
  @@index([rule, subjectKey, resolvedAt])
}

/// Invoice records. Dummy payment flow in Phase B writes these via the
/// super admin's "Mark paid" / "Mark failed" buttons. No real Stripe yet —
/// externalId column is there for future integration.
model Invoice {
  id          String    @id @default(cuid())
  tenantId    String
  planSlug    String    // snapshot of plan at invoice time (history-safe)
  amountCents Int
  currency    String    @default("USD")
  status      String    @default("pending") // "pending" | "paid" | "failed" | "refunded"
  periodStart DateTime
  periodEnd   DateTime
  paidAt      DateTime?
  failedAt    DateTime?
  notes       String?   @db.Text
  externalId  String? // stripe subscription/invoice id, future use
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([status])
  @@index([periodEnd])
}
