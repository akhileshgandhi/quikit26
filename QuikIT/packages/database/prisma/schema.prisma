model Goal {
  id           String  @id @default(cuid())
  tenantId     String
  ownerId      String // the person the goal belongs to
  parentGoalId String? // optional hierarchy (company → team → individual)

  title       String
  description String? @db.Text
  category    String? // "business" | "personal" | "team" | custom

  // Measurement
  targetValue     Float?
  currentValue    Float?  @default(0)
  unit            String? // "%", "$", "users", etc.
  progressPercent Float?  @default(0) // computed client-side or on update

  // Timebox
  quarter String? // Q1 | Q2 | Q3 | Q4 (null = annual)
  year    Int

  // State machine
  status String @default("draft") // draft | active | on-track | at-risk | completed | abandoned

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String
  completedAt DateTime?

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner      User   @relation("GoalOwner", fields: [ownerId], references: [id])
  parentGoal Goal?  @relation("GoalHierarchy", fields: [parentGoalId], references: [id], onDelete: SetNull)
  childGoals Goal[] @relation("GoalHierarchy")

  @@index([tenantId])
  @@index([ownerId])
  @@index([tenantId, year, quarter])
  @@index([parentGoalId])
}

