// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime URL — points at the pooler (transaction mode) in prod/uat.
  // Append ?pgbouncer=true&connection_limit=1&pool_timeout=10 when routed via PgBouncer.
  url       = env("DATABASE_URL")
  // Migrations URL — unpooled, so DDL and advisory locks work. Prisma uses this
  // automatically for `prisma migrate` / `prisma db push`.
  // IMPORTANT: Prisma 5.22 does NOT fall back to `url` when this env var is
  // unset — it errors with P1012. Local dev must set DATABASE_URL_DIRECT even
  // when pointing at the same URL as DATABASE_URL (a pooler-less Postgres is
  // its own direct URL).
  directUrl = env("DATABASE_URL_DIRECT")
}

// ============================================================================
// APP REGISTRY (Multi-App Platform)
// ============================================================================

model App {
  id          String  @id @default(cuid())
  name        String // "QuikScale"
  slug        String  @unique // "quikscale"
  description String?
  iconUrl     String? // URL or path to app icon
  baseUrl     String // "https://quikscale.vercel.app" or "/" for self
  status      String  @default("active") // active | coming_soon | disabled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userAccess   UserAppAccess[]
  oauthClient  OAuthClient?
  moduleFlags  AppModuleFlag[]
  healthChecks AppHealthCheck[]
  tenantAccess TenantAppAccess[]

  @@index([slug])
  @@index([status])
}

// ============================================================================
// OAUTH2 / OIDC — QuikIT as Identity Provider
// ============================================================================

model OAuthClient {
  id           String   @id @default(cuid())
  appId        String   @unique
  clientId     String   @unique // "quikscale", "admin", etc.
  clientSecret String // bcrypt-hashed
  redirectUris String[] // ["http://localhost:3004/api/auth/callback/quikit"]
  scopes       String[] @default(["openid", "profile", "email", "tenant"])
  grantTypes   String[] @default(["authorization_code", "refresh_token"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model OAuthCode {
  id                  String   @id @default(cuid())
  code                String   @unique
  clientId            String
  userId              String
  tenantId            String
  scopes              String[]
  codeChallenge       String? // PKCE S256 challenge
  codeChallengeMethod String? // "S256"
  redirectUri         String
  expiresAt           DateTime
  used                Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([code])
  @@index([expiresAt])
}

model OAuthRefreshToken {
  id          String   @id @default(cuid())
  token       String   @unique
  accessToken String?  @unique
  clientId    String
  userId      String
  tenantId    String
  scopes      String[]
  expiresAt   DateTime
  revoked     Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([token])
  @@index([accessToken])
  @@index([userId, clientId])
}

model UserAppAccess {
  id       String @id @default(cuid())
  userId   String
  tenantId String
  appId    String
  role     String @default("member") // viewer | member | admin

  grantedBy String?
  grantedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  app    App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId, appId])
  @@index([userId])
  @@index([tenantId])
  @@index([appId])
}

// ============================================================================
// CORE MULTI-TENANT TABLES
// ============================================================================

model Tenant {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  status      String  @default("active")

  fiscalYearStart   Int @default(1)
  quarterStartMonth Int @default(1)
  weekStartDay      Int @default(1)

  logoUrl    String?
  brandColor String? @default("#0066cc")

  plan         String  @default("startup")
  billingEmail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  users                   Membership[]
  userAppAccess           UserAppAccess[]
  teams                   Team[]
  userTeams               UserTeam[]
  kpis                    KPI[]
  priorities              Priority[]
  wwwItems                WWWItem[]
  categoryMasters         CategoryMaster[]
  meetings                Meeting[]
  meetingTemplates        MeetingTemplate[]
  dailyHuddles            DailyHuddle[]
  quarterSettings         QuarterSetting[]
  opspDocuments           OPSPDocument[]
  opppPlans               OPSPPlan[]
  opspData                OPSPData[]
  opspReviewEntries       OPSPReviewEntry[]
  accountabilityFunctions AccountabilityFunction[]
  habits                  HabitAssessment[]
  auditLogs               AuditLog[]
  notifications           Notification[]
  featureFlags            FeatureFlag[]
  appModuleFlags          AppModuleFlag[]
  performanceReviews      PerformanceReview[]
  talentAssessments       TalentAssessment[]
  goals                   Goal[]
  oneOnOnes               OneOnOne[]
  feedbackEntries         FeedbackEntry[]
  sessionEvents           SessionEvent[]
  tenantAppAccess         TenantAppAccess[]
  invoices                Invoice[]

  @@index([slug])
  @@index([status])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String?
  firstName     String
  lastName      String
  avatar        String?
  isSuperAdmin  Boolean   @default(false)

  country     String?
  timezone    String?
  bio         String?
  themeMode   String? @default("light")
  accentColor String? @default("#0066cc")

  kpiFrozenCol       String?
  priorityFrozenCol  String?
  wwwFrozenCol       String?
  kpiHiddenCols      String?
  priorityHiddenCols String?
  wwwHiddenCols      String?
  kpiSort            String?
  prioritySort       String?
  wwwSort            String?
  kpiColWidths       String?
  priorityColWidths  String?
  wwwColWidths       String?

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
  appAccess   UserAppAccess[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSignInAt DateTime?

  userTeams               UserTeam[]
  kpisOwned               KPI[]                    @relation("KPIOwner")
  prioritiesOwned         Priority[]               @relation("PriorityOwner")
  kpiNotes                KPINote[]
  opppPlan                OPSPPlan?
  opspData                OPSPData[]
  opspReviewEntries       OPSPReviewEntry[]
  accountabilityFunctions AccountabilityFunction[]
  reviewsGiven            PerformanceReview[]      @relation("ReviewsGiven")
  reviewsReceived         PerformanceReview[]      @relation("ReviewsReceived")
  talentAssessed          TalentAssessment[]       @relation("TalentAssessed")
  talentAssessor          TalentAssessment[]       @relation("TalentAssessor")
  goalsOwned              Goal[]                   @relation("GoalOwner")
  oneOnOnesAsManager      OneOnOne[]               @relation("OneOnOneManager")
  oneOnOnesAsReport       OneOnOne[]               @relation("OneOnOneReport")
  feedbackGiven           FeedbackEntry[]          @relation("FeedbackFrom")
  feedbackReceived        FeedbackEntry[]          @relation("FeedbackTo")
  sessionEvents           SessionEvent[]

  @@index([email])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  access_token      String?  @db.Text
  token_type        String?
  scope             String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Membership {
  id       String @id @default(cuid())
  tenantId String
  userId   String
  role     String

  teamId            String?
  customPermissions String[]

  invitationToken String?   @unique
  invitedAt       DateTime?
  acceptedAt      DateTime?
  status          String    @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team?  @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([teamId])
  @@index([role])
  @@index([tenantId, role])
}

// ── User ↔ Team many-to-many (a user can belong to multiple teams) ──────────

model UserTeam {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  teamId    String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, teamId])
  @@index([tenantId])
  @@index([userId])
  @@index([teamId])
}

// ============================================================================
// ORGANIZATIONAL STRUCTURE
// ============================================================================

model Team {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  description String?
  slug        String

  parentTeamId String?
  headId       String?

  color String? @default("#0066cc")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  deletedAt DateTime?

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members                 Membership[]
  userTeams               UserTeam[]
  kpis                    KPI[]
  priorities              Priority[]
  parentTeam              Team?                    @relation("TeamHierarchy", fields: [parentTeamId], references: [id], onDelete: SetNull)
  childTeams              Team[]                   @relation("TeamHierarchy")
  accountabilityFunctions AccountabilityFunction[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([parentTeamId])
  @@index([deletedAt])
}

model AccountabilityFunction {
  id       String @id @default(cuid())
  tenantId String

  name        String
  description String?

  teamId           String?
  parentFunctionId String?
  assignedToUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  team           Team?                    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  assignedTo     User?                    @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)
  childFunctions AccountabilityFunction[] @relation("FunctionHierarchy")
  parentFunction AccountabilityFunction?  @relation("FunctionHierarchy", fields: [parentFunctionId], references: [id], onDelete: SetNull)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([assignedToUserId])
}

// ============================================================================
// KPI MODULE
// ============================================================================

model KPI {
  id       String @id @default(cuid())
  tenantId String

  name               String
  description        String?
  kpiLevel           String   @default("individual") // "individual" | "team"
  owner              String?
  // Team KPI owners (multi-select). Each owner has a contribution % stored in ownerContributions.
  ownerIds           String[] @default([])
  // JSON map: { userId: contributionPercentage }  — sum must equal 100 for team KPIs
  ownerContributions Json?
  teamId             String?

  parentKPIId String?

  quarter String @default("Q1")
  year    Int

  measurementUnit  String
  target           Float?
  quarterlyGoal    Float?
  qtdGoal          Float?
  qtdAchieved      Float?
  currentWeekValue Float?
  progressPercent  Float? @default(0)

  status       String @default("active")
  healthStatus String @default("on-track")

  divisionType       String  @default("Cumulative")
  weeklyTargets      Json?
  // Team KPI per-owner weekly targets: { userId: { weekNumber: value } }
  // Source of truth for team KPI breakdowns; weeklyTargets holds the aggregate sum.
  weeklyOwnerTargets Json?
  currency           String?
  targetScale        String?
  reverseColor       Boolean @default(false)

  lastNotes   String?
  lastNotesAt DateTime?
  lastNotedBy String?

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String
  updatedBy String?

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner_user   User?            @relation("KPIOwner", fields: [owner], references: [id])
  team         Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  parentKPI    KPI?             @relation("KPICascade", fields: [parentKPIId], references: [id], onDelete: SetNull)
  childKPIs    KPI[]            @relation("KPICascade")
  weeklyValues KPIWeeklyValue[]
  notes        KPINote[]
  logs         KPILog[]

  @@index([tenantId])
  @@index([owner])
  @@index([teamId])
  @@index([kpiLevel])
  @@index([parentKPIId])
  @@index([status])
  @@index([healthStatus])
  @@index([quarter, year])
}

model KPIWeeklyValue {
  id       String  @id @default(cuid())
  tenantId String
  kpiId    String
  // Phase 2: userId attributes this weekly value to a specific user.
  //   - Individual KPI: always set to kpi.owner (enforced by API + backfilled for existing rows)
  //   - Team KPI: set to one of kpi.ownerIds (each owner has their own row per week)
  //   - Legacy rows may be null until migration completes
  userId   String?

  weekNumber Int
  value      Float?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String
  updatedBy String?

  kpi KPI @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@unique([kpiId, userId, weekNumber])
  @@index([tenantId])
  @@index([kpiId])
  @@index([userId])
}

model KPINote {
  id       String @id @default(cuid())
  tenantId String
  kpiId    String

  content  String @db.Text
  authorId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kpi    KPI  @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([kpiId])
  @@index([authorId])
}

model KPILog {
  id       String @id @default(cuid())
  tenantId String
  kpiId    String

  action    String
  oldValue  String? @db.Text
  newValue  String? @db.Text
  changedBy String
  reason    String?

  createdAt DateTime @default(now())

  kpi KPI @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([kpiId])
  @@index([createdAt])
  @@index([kpiId, createdAt])
}

// ============================================================================
// PRIORITY MODULE
// ============================================================================

model Priority {
  id       String @id @default(cuid())
  tenantId String

  name        String
  description String?
  owner       String
  teamId      String?

  quarter   String
  year      Int
  startWeek Int?
  endWeek   Int?

  overallStatus String @default("not-started")

  notes String? @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String
  updatedBy String?
  deletedAt DateTime?

  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner_user     User?                  @relation("PriorityOwner", fields: [owner], references: [id])
  team           Team?                  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  weeklyStatuses PriorityWeeklyStatus[]

  @@index([tenantId])
  @@index([owner])
  @@index([teamId])
  @@index([quarter, year])
  @@index([tenantId, owner])
  @@index([deletedAt])
}

model PriorityWeeklyStatus {
  id         String @id @default(cuid())
  priorityId String

  weekNumber Int
  status     String
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String?

  priority Priority @relation(fields: [priorityId], references: [id], onDelete: Cascade)

  @@unique([priorityId, weekNumber])
  @@index([priorityId])
}

// ============================================================================
// WWW MODULE (Who, What, When)
// ============================================================================

model WWWItem {
  id       String @id @default(cuid())
  tenantId String

  who  String
  what String
  when DateTime

  createdInMeetingId String?
  linkedPriorityId   String?
  linkedKPIId        String?

  status   String  @default("not-started")
  notes    String? @db.Text
  category String?

  originalDueDate DateTime?
  revisedDates    String[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String
  updatedBy String?
  deletedAt DateTime?

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  meeting      Meeting?         @relation(fields: [createdInMeetingId], references: [id], onDelete: SetNull)
  revisionLogs WWWRevisionLog[]

  @@index([tenantId])
  @@index([who])
  @@index([when])
  @@index([status])
  @@index([createdAt])
  @@index([tenantId, who])
  @@index([deletedAt])
}

model WWWRevisionLog {
  id        String @id @default(cuid())
  wwwItemId String

  oldDueDate DateTime
  newDueDate DateTime
  reason     String?
  changedBy  String

  createdAt DateTime @default(now())

  wwwItem WWWItem @relation(fields: [wwwItemId], references: [id], onDelete: Cascade)

  @@index([wwwItemId])
  @@index([createdAt])
}

// ============================================================================
// CATEGORY MASTER
// ============================================================================

model CategoryMaster {
  id       String @id @default(cuid())
  tenantId String

  name        String
  dataType    String // "Number" | "Percentage" | "Currency"
  currency    String? // e.g. "INR", "USD" — only when dataType = "Currency"
  description String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([dataType])
}

// ============================================================================
// MEETING MODULE
// ============================================================================

model Meeting {
  id       String @id @default(cuid())
  tenantId String

  templateId String?
  name       String
  cadence    String

  scheduledAt DateTime
  duration    Int

  location    String?
  meetingLink String?

  agenda     String? @db.Text
  decisions  String? @db.Text
  blockers   String? @db.Text
  highlights String? @db.Text

  startedOnTime  Boolean @default(false)
  endedOnTime    Boolean @default(false)
  formatFollowed Boolean @default(false)
  followUpRate   Float?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String
  updatedBy   String?
  completedAt DateTime?
  deletedAt   DateTime?

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template          MeetingTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  attendees         MeetingAttendee[]
  generatedWWWItems WWWItem[]
  metrics           MeetingMetric[]

  @@index([tenantId])
  @@index([cadence])
  @@index([scheduledAt])
  @@index([tenantId, scheduledAt])
  @@index([tenantId, cadence, scheduledAt]) // Phase 4: covers the most-queried meeting list pattern
  @@index([deletedAt])
}

model MeetingTemplate {
  id       String @id @default(cuid())
  tenantId String

  name        String
  cadence     String
  description String?

  sections         String[]
  defaultAttendees String[]

  duration Int @default(60)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  meetings Meeting[]

  @@index([tenantId])
}

model MeetingAttendee {
  id        String @id @default(cuid())
  meetingId String
  userId    String

  attended   Boolean   @default(false)
  attendedAt DateTime?
  leftAt     DateTime?

  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([meetingId])
}

model MeetingMetric {
  id        String @id @default(cuid())
  meetingId String

  metricName String
  value      Float

  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

// ============================================================================
// DAILY HUDDLE
// ============================================================================

model DailyHuddle {
  id       String @id @default(cuid())
  tenantId String

  meetingDate            DateTime
  callStatus             String // "Scheduled" | "Held" | "Cancelled" | "Rescheduled"
  clientName             String?
  absentMembers          String?
  actualStartTime        String? // "HH:MM" 24h
  actualEndTime          String? // "HH:MM" 24h
  yesterdaysAchievements Boolean  @default(false)
  stuckIssues            Boolean  @default(false)
  todaysPriority         Boolean  @default(false)
  notesKPDashboard       String?  @db.Text
  otherNotes             String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([meetingDate])
}

// ============================================================================
// OPSP MODULE (One-Page Strategic Plan)
// ============================================================================

// ============================================================================
// OPSP DATA (Create OPSP Form — all fields)
// ============================================================================

model OPSPData {
  id          String @id @default(cuid())
  tenantId    String
  userId      String
  year        Int
  quarter     String // Q1 | Q2 | Q3 | Q4
  status      String @default("draft") // draft | finalized
  targetYears Int    @default(5) // 3 or 5

  // PEOPLE
  employees    Json? // String[3]
  customers    Json? // String[3]
  shareholders Json? // String[3]

  // CORE VALUES / PURPOSE
  coreValues String? @db.Text
  purpose    String? @db.Text
  actions    Json? // String[5]
  profitPerX String?
  bhag       String? @db.Text

  // TARGETS (3-5 yrs)
  targetRows       Json? // [{category,projected,y1,y2,y3,y4,y5}]
  sandbox          String? @db.Text
  keyThrusts       Json? // [{desc,owner}] ×5
  brandPromiseKPIs String? @db.Text
  brandPromise     String? @db.Text

  // GOALS (1 yr)
  goalRows              Json? // [{category,projected,q1,q2,q3,q4}]
  keyInitiatives        Json? // [{desc, owner}] ×5 — 1 Year Priorities, matches keyThrusts shape
  criticalNumGoals      Json? // {title,bullets:String[4]}
  balancingCritNumGoals Json?

  // People-section bottom
  processItems Json? // String[3]
  weaknesses   Json? // String[3]

  // PROCESS section
  makeBuy       Json? // String[3]
  sell          Json? // String[3]
  recordKeeping Json? // String[3]

  // ACTIONS QTR
  actionsQtr              Json? // [{category,projected}] ×5
  rocks                   Json? // [{desc, owner}] ×5 — Quarterly Priorities (matches keyInitiatives shape)
  criticalNumProcess      Json?
  balancingCritNumProcess Json?

  // THEME
  theme            String? @db.Text
  scoreboardDesign String? @db.Text
  celebration      String? @db.Text
  reward           String? @db.Text

  // YOUR ACCOUNTABILITY
  kpiAccountability    Json? // [{kpi,goal}] ×5
  quarterlyPriorities  Json? // [{priority,dueDate}] ×5
  criticalNumAcct      Json?
  balancingCritNumAcct Json?

  // TRENDS
  trends Json? // String[6]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String
  updatedBy String?

  reviewEntries OPSPReviewEntry[]

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, year, quarter])
  @@index([tenantId])
  @@index([userId])
  @@index([year, quarter])
}

// ============================================================================
// OPSP REVIEW ENTRIES (Achieved actuals tracked per period per category)
// ============================================================================

model OPSPReviewEntry {
  id            String   @id @default(cuid())
  tenantId      String
  opspId        String
  userId        String // who entered/last updated this value
  horizon       String // "quarter" | "yearly" | "3to5year"
  rowIndex      Int // index in source array (actionsQtr[0], goalRows[1], etc.)
  category      String // denormalized from OPSP for query convenience
  period        String // "m1"|"m2"|"m3" | "q1"|"q2"|"q3"|"q4" | "y1"|"y2"|"y3"|"y4"|"y5"
  targetValue   Decimal? @db.Decimal(20, 4) // snapshot of OPSP target at review time
  achievedValue Decimal? @db.Decimal(20, 4)
  comment       String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String?

  tenant Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  opsp   OPSPData @relation(fields: [opspId], references: [id], onDelete: Cascade)
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, opspId, horizon, rowIndex, period])
  @@index([tenantId])
  @@index([opspId])
  @@index([userId])
}

