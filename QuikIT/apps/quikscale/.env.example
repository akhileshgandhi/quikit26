# ============================================================================
# DATABASE — Neon Postgres (production), any Postgres (local dev)
# ============================================================================
# RUNTIME URL. Prisma Client reads this.
#
# Production (Neon pooler):
#   postgres://USER:PASSWORD@ep-xxx-POOLER.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connection_limit=1&pool_timeout=10
#   Note the -pooler suffix in the hostname. Connect to the POOLER endpoint
#   and append ?pgbouncer=true&connection_limit=1&pool_timeout=10.
#
# Local dev (direct to a local Postgres):
#   postgresql://USER:PASSWORD@localhost:5432/quikscale_dev
DATABASE_URL="postgres://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connection_limit=1&pool_timeout=10"

# MIGRATIONS URL. REQUIRED. Prisma 5.22 reads this for `prisma migrate` /
# `prisma db push` and errors (P1012) if declared in schema.prisma but unset.
# It MUST bypass the connection pooler (advisory locks and DDL need a real
# session). On Neon, drop `-pooler` from the hostname. For local dev without
# a pooler, set this to the same URL as DATABASE_URL.
#
# Production (Neon direct):
#   postgres://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DB?sslmode=require
#
# Local dev (same as DATABASE_URL — no pooler):
#   postgresql://USER:PASSWORD@localhost:5432/quikscale_dev
DATABASE_URL_DIRECT="postgres://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DB?sslmode=require"

# ============================================================================
# REDIS — Upstash (production), any Redis (local dev)
# ============================================================================
# Used for distributed rate limiting (P0-3) and future session/query caches.
# When unset, rate limiting falls back to in-memory per-lambda counters, which
# are bypassable across lambdas — acceptable ONLY in dev.
#
# Production (Upstash redis-over-TLS, recommended):
#   rediss://default:PASSWORD@HOST.upstash.io:PORT
#
# Local dev:
#   redis://localhost:6379
REDIS_URL="rediss://default:PASSWORD@HOST.upstash.io:PORT"

# ============================================================================
# NEXTAUTH
# ============================================================================
# Generate secret: openssl rand -base64 32
# NEXTAUTH_URL is the public origin of THIS app (quikscale). Used by NextAuth
# for cookie scoping, callback URLs, and id_token issuer checks. MUST be set
# in production. A localhost fallback would break SSO callback handling.
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="https://quikscale.vercel.app"

# ============================================================================
# QUIKIT SSO (when this app authenticates via QuikIT)
# ============================================================================
# Base URL of the QuikIT gateway. Required in production for OAuth discovery
# and for the AppSwitcher "View all apps" link. Also exposed to the client as
# NEXT_PUBLIC_QUIKIT_URL so NextAuth's signIn("quikit") knows where to send
# the browser.
QUIKIT_URL="https://quik-it-auth.vercel.app"
NEXT_PUBLIC_QUIKIT_URL="https://quik-it-auth.vercel.app"
QUIKIT_CLIENT_ID="quikscale"
QUIKIT_CLIENT_SECRET="set-on-vercel-only"

# ============================================================================
# OAUTH PROVIDERS (Optional - for future)
# ============================================================================
GITHUB_ID=""
GITHUB_SECRET=""
GOOGLE_ID=""
GOOGLE_SECRET=""

# ============================================================================
# AI FEATURES (Phase 13)
# ============================================================================
ANTHROPIC_API_KEY=""

# ============================================================================
# EXTERNAL SERVICES (Future)
# ============================================================================
STRIPE_SECRET_KEY=""
SLACK_BOT_TOKEN=""
SENDGRID_API_KEY=""

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL="info"
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_AI_INSIGHTS="false"
FEATURE_POWER_OF_ONE="true"
FEATURE_SLACK_INTEGRATION="false"
