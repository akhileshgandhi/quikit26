# =============================================================================
# QuikIT Gateway (IdP) — Environment Variables
# =============================================================================
# Copy this file to .env.local for local dev.
# For production, set these on the Vercel project `quik-it` dashboard.
# See docs/plans/VERCEL-PROD-SETUP.md for the full checklist.

# -----------------------------------------------------------------------------
# DATABASE — Neon Postgres (prod) / any Postgres (dev)
# -----------------------------------------------------------------------------
# RUNTIME URL. Prisma Client reads this.
#
# Production (Neon pooler):
#   postgres://USER:PASSWORD@ep-xxx-POOLER.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connection_limit=1&pool_timeout=10
#
# Local dev:
#   postgresql://USER:PASSWORD@localhost:5432/quikscale_dev
DATABASE_URL="postgres://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connection_limit=1&pool_timeout=10"

# MIGRATIONS URL. Unpooled. On Neon, drop `-pooler` from the host.
# REQUIRED — Prisma 5.22 errors (P1012) if this is declared in schema.prisma
# but unset in the environment. For local dev without a pooler, point it at
# the same URL as DATABASE_URL.
DATABASE_URL_DIRECT="postgres://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DB?sslmode=require"

# -----------------------------------------------------------------------------
# REDIS — Upstash (prod) / any Redis (dev). Required in prod for P0-3 limiter.
# -----------------------------------------------------------------------------
REDIS_URL="rediss://default:PASSWORD@HOST.upstash.io:PORT"

# -----------------------------------------------------------------------------
# NEXTAUTH — REQUIRED in production
# -----------------------------------------------------------------------------
# Generate secret: openssl rand -base64 32
# NEXTAUTH_URL becomes the OIDC `iss` claim on every signed id_token and the
# `issuer` field on /.well-known/openid-configuration. If it's missing in
# prod the app refuses to start (no silent localhost fallback — would break
# every OAuth client that verifies the id_token).
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://quik-it-auth.vercel.app"

# -----------------------------------------------------------------------------
# OAuth IdP JWT signing keys — REQUIRED in production
# -----------------------------------------------------------------------------
# Both keys must be from the same RSA pair. If either is missing in prod,
# the IdP generates an ephemeral keypair per lambda — id_tokens signed on
# one lambda can't verify against the JWKS served by another. See
# apps/quikit/lib/oauth.ts for the PEM normalization that accepts: full PEM
# with real newlines, full PEM with literal \n escapes, base64-encoded PEM,
# or the bare base64 body (our env-var UI stores this shape).
#
# Generate locally:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in private.pem -pubout -out public.pem
# JWT_SIGNING_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_SIGNING_KEY_PUBLIC="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# -----------------------------------------------------------------------------
# App registry redirects — used by /apps launcher to link out to each app
# -----------------------------------------------------------------------------
QUIKSCALE_URL="https://quikscale.vercel.app"
ADMIN_URL="https://quik-it-admin.vercel.app"
