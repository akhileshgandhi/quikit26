{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "quikit",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "export PATH=/opt/homebrew/bin:/usr/local/bin:$PATH && exec npx turbo dev --filter=quikit"],
      "port": 3000
    },
    {
      "name": "quikscale",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "export PATH=/opt/homebrew/bin:/usr/local/bin:$PATH && exec npx turbo dev --filter=quikscale"],
      "port": 3004,
      "autoPort": false
    },
    {
      "name": "admin",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "export PATH=/opt/homebrew/bin:/usr/local/bin:$PATH && exec npx turbo dev --filter=admin"],
      "port": 3005
    },
    {
      "name": "all",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "export PATH=/opt/homebrew/bin:/usr/local/bin:$PATH && exec npm run dev"],
      "port": 3000
    }
  ]
}
